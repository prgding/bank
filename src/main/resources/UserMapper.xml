<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="dao.ActDao">

    <update id="update">
        update t_act
        set balance = #{balance}
        where actno = #{username};
    </update>

    <select id="select" resultType="pojo.User">
        select *
        from t_act
        where actno = #{username};
    </select>
</mapper>